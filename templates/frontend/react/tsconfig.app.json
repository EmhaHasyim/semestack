{
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"target": "es2023",
		"module": "esnext",
		"lib": ["DOM", "DOM.Iterable", "ES2023"],
		"types": ["vite/client"],
		"jsx": "react-jsx",
		"noEmit": true,
		"allowJs": true,
		"checkJs": true,
		"moduleDetection": "force",
		"strict": true,
		"skipLibCheck": true,
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.js"]
}
