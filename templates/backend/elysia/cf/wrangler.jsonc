{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "semestack",
	"compatibility_date": "2026-05-15",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./src/server/index.ts",
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist/client",
	},
	"observability": {
		"enabled": true,
	},
}
